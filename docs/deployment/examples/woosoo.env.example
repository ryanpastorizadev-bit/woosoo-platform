# ==================================================
# Woosoo Local Deployment Config
# Copy to: /etc/woosoo/woosoo.env
# Edit this file, then run:
#   sudo bash scripts/deployment/apply-woosoo-config.sh
#
# The apply script uses require_var for the REQUIRED values below.
# ==================================================

# REQUIRED
# Networks used in production:
#   HOME (dev/test): Pi = 192.168.100.42, POS = 192.168.100.7,    gateway = 192.168.100.1
#   RESTO (prod):    Pi = 192.168.1.31,   POS = 192.168.1.32,     gateway = 192.168.1.1
# Per AGENTS.md the production POS static IP is 192.168.1.32. Verify before deploy.
WOOSOO_HOST="woosoo.local"
WOOSOO_SERVER_IP="192.168.100.42"
WOOSOO_GATEWAY="192.168.100.1"
WOOSOO_CIDR="24"
# Path to the Laravel app repo (woosoo-nexus). The .env is still written here.
WOOSOO_NEXUS_PATH="/opt/woosoo/woosoo-platform/woosoo-nexus"
WOOSOO_SCHEME="https"

# OPTIONAL (has defaults or deployment-specific values)
# Platform repo root (governance + orchestration: compose.yaml, docker/, scripts).
# Default: parent dir of WOOSOO_NEXUS_PATH. docker compose runs from here.
WOOSOO_PLATFORM_PATH="/opt/woosoo/woosoo-platform"
# Branches pulled per-repo by deploy.sh (sibling 3-repo model).
# Active integration branch is `dev` per the project branching policy. Override
# per-repo only if you really need to deploy a different branch for testing.
# Single-knob convenience: WOOSOO_DEPLOY_BRANCH=<branch> overrides both at once.
WOOSOO_DEPLOY_BRANCH="dev"
WOOSOO_NEXUS_BRANCH="dev"
WOOSOO_TABLET_BRANCH="dev"
WOOSOO_DNS_FORWARDERS="1.1.1.1 8.8.8.8"
WOOSOO_NM_CONNECTION=""
# Compose now runs from WOOSOO_PLATFORM_PATH with the platform-root compose.yaml.
# --env-file ./woosoo-nexus/.env feeds ${...} interpolation (PUBLIC_HOST, keys).
WOOSOO_DOCKER_COMPOSE="docker compose --env-file ./woosoo-nexus/.env -f compose.yaml"
WOOSOO_TIMEZONE="Asia/Manila"

# POS host (krypton_woosoo MariaDB). Home = 192.168.100.7. Resto/prod = 192.168.1.32.
WOOSOO_POS_HOST="192.168.100.7"
WOOSOO_POS_PORT="3308"
WOOSOO_POS_DATABASE="krypton_woosoo"
WOOSOO_POS_USERNAME="krypton_readonly"
WOOSOO_POS_PASSWORD=""

# Per-network POS DB credentials used by scripts/deployment/switch-network.sh
HOME_DB_POS_USERNAME="woosoo_pos"
HOME_DB_POS_PASSWORD=""
RESTO_DB_POS_USERNAME="user_1"
RESTO_DB_POS_PASSWORD=""

WOOSOO_DB_DATABASE="woosoo"
WOOSOO_DB_USERNAME="woosoo"
WOOSOO_DB_PASSWORD="change_this_password"
WOOSOO_DB_ROOT_PASSWORD="change_this_root_password"

WOOSOO_REVERB_APP_ID="woosoo"
WOOSOO_REVERB_APP_KEY="change_this_reverb_key"
WOOSOO_REVERB_APP_SECRET="change_this_reverb_secret"

WOOSOO_DEVICE_AUTH_PASSCODE="change_this_passcode"

WOOSOO_ALIASES="api.woosoo.local tablet.woosoo.local"

WOOSOO_APP_SERVICE="app"
WOOSOO_NGINX_SERVICE="nginx"
WOOSOO_REVERB_SERVICE="reverb"
WOOSOO_QUEUE_SERVICE="queue"
WOOSOO_SCHEDULER_SERVICE="scheduler"
WOOSOO_MYSQL_SERVICE="mysql"

WOOSOO_BACKUP_DIR="/opt/woosoo/backups"
WOOSOO_BACKUP_RETENTION_DAYS="14"
WOOSOO_APPLY_STATIC_IP="true"
WOOSOO_RESTART_DOCKER="true"
# Set to true only when applying static IP changes over SSH and you accept the disconnect risk.
FORCE_APPLY_STATIC_IP="false"
