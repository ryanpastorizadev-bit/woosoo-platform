{
  "permissions": {
    "defaultMode": "plan",
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./storage/oauth-private.key)",
      "Read(./storage/oauth-public.key)",
      "Read(./storage/logs/**)",
      "Read(./.git/config)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      { "matcher": "", "hooks": [{ "type": "command", "command": "powershell -NonInteractive -NoProfile -File scripts/vault-inject.ps1" }] }
    ]
  }
}
