# Root safety-net .gitignore for the woosoo-platform multi-repo sibling workspace.
# Per-app .gitignore files (woosoo-nexus/, tablet-ordering-pwa/, woosoo-print-bridge/)
# remain authoritative for app-specific ignores; this file is the cross-cutting guard
# so the branch/rollback protocol (git add / commit / restore) can never capture
# secrets or dependency/build trees. See AGENTS.md "Config integrity" + .claude/settings.json.

# --- Secrets / credentials (NEVER commit) ---
.env
.env.*
!.env.example
!**/.env.example
woosoo.env
secrets/
**/secrets/
config/credentials.json
**/storage/oauth-private.key
**/storage/oauth-public.key
*.pem
*.key
!**/*.pub.key

# --- Dependencies ---
node_modules/
vendor/
.pnpm-store/

# --- Build / generated output ---
dist/
build/
.output/
.nuxt/
.nitro/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
public/build/
public/hot

# --- Laravel runtime ---
**/storage/logs/
**/storage/framework/cache/
**/storage/framework/sessions/
**/storage/framework/views/
**/bootstrap/cache/*.php

# --- Logs / temp ---
*.log
npm-debug.log*
yarn-error.log*

# --- Scratch review mirrors (real code lives in woosoo-nexus) ---
.kds-review/

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
*.swp
.idea/

# --- Obsidian (machine-local layout + downloaded plugins; config via scripts/obsidian-bootstrap.ps1) ---
.obsidian/
*.canvas
*.base
# Intentional, hub-linked canvases are tracked (negate the blanket *.canvas ignore above):
!docs/architecture/SYSTEM_MAP.canvas
!docs/cases/DEPLOY_SEQUENCE.canvas

# --- Independent app repos (managed as their own git repos / sibling model) ---
# The platform repo is the orchestration/governance layer only.
/woosoo-nexus/
/tablet-ordering-pwa/
/woosoo-print-bridge/

# --- Product binary assets (not governance/code) ---
/Woosoo Food Assets/

# --- Machine-local Claude Code settings (not shared) ---
.claude/settings.local.json

# --- Machine-local skill loader links (canonical source is .agents/skills/) ---
# .claude/skills/ contains symlinks/junctions the harness uses to load skills.
# They are recreated locally by scripts/setup-skills.ps1 — do not commit.
.claude/skills/
# --- Machine-local Claude Code worktree tracking (recreated by harness; not shared) ---
.claude/worktrees/

# --- Machine-local Codex runtime config (sandbox_mode etc.; not shared) ---
.codex/config.toml

# --- Editor-local Windsurf workspace (not a supported runner; do not commit) ---
/.windsurf/

# --- Accidental artifact (empty file from a stray shell redirect) ---
/null

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/
/.playwright-mcp/

# Personal working scratchpad (private, not checked in)
/CLAUDE.local.md
