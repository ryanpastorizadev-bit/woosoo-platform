# Root safety-net .gitignore for the woosoo-platform monorepo.
# Per-app .gitignore files (woosoo-nexus/, tablet-ordering-pwa/, woosoo-print-bridge/)
# remain authoritative for app-specific ignores; this file is the cross-cutting guard
# so the branch/rollback protocol (git add / commit / restore) can never capture
# secrets or dependency/build trees. See AGENTS.md "Config integrity" + .claude/settings.json.

# --- Secrets / credentials (NEVER commit) ---
.env
.env.*
!.env.example
!**/.env.example
secrets/
**/secrets/
config/credentials.json
**/storage/oauth-private.key
**/storage/oauth-public.key
*.pem
*.key
!**/*.pub.key

# --- Dependencies ---
node_modules/
vendor/
.pnpm-store/

# --- Build / generated output ---
dist/
build/
.output/
.nuxt/
.nitro/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
public/build/
public/hot

# --- Laravel runtime ---
**/storage/logs/
**/storage/framework/cache/
**/storage/framework/sessions/
**/storage/framework/views/
**/bootstrap/cache/*.php

# --- Logs / temp ---
*.log
npm-debug.log*
yarn-error.log*

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
*.swp
.idea/

# --- Independent app repos (managed as their own git repos / sibling model) ---
# The platform repo is the orchestration/governance layer only.
/woosoo-nexus/
/tablet-ordering-pwa/
/woosoo-print-bridge/

# --- Product binary assets (not governance/code) ---
/Woosoo Food Assets/

# --- Machine-local Claude Code settings (not shared) ---
.claude/settings.local.json

# --- Editor-local Windsurf workspace (not a supported runner; do not commit) ---
/.windsurf/

# --- Accidental artifact (empty file from a stray shell redirect) ---
/null
